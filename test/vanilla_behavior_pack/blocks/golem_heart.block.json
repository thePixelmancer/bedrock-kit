{
	"format_version": "1.21.120",
	"minecraft:block": {
		"description": {
			"name": "Blackstone Golem Heart",
			"identifier": "tsunami_dungeons:golem_heart",
			//content guide
			"description": "Spawner for spawning hard difficulty monsters",
			"menu_category": {
				"category": "construction"
			},
			"states": {
				"@namespace:waves_remaining": {"values": {"min": 0, "max": 15}},
				"@namespace:seconds": {"values": {"min": 0, "max": 15}},
				"@namespace:can_deal_damage": [ "ready", "dealing_damage", "no"]
			}
		},
		"components": {
			"tsunami_dungeons:golem_heart": {},
			"tag:minecraft:is_pickaxe_item_destructible": {},
			"minecraft:geometry": {
				"identifier": "minecraft:geometry.full_block"
			},
			"minecraft:loot": "loot_tables/blocks/golem_heart.json",
			"minecraft:material_instances": {
				"*": {
					"texture": "tsunami_dungeons:golem_heart",
					"render_method": "alpha_test"
				}
			},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 25,
				"item_specific_speeds": [
					{
						"destroy_speed": 5,
						"item": {
							"tags": "q.all_tags('minecraft:is_tool', 'minecraft:is_pickaxe')"
						}
					}
				]
			},
			"minecraft:tick": {
				"interval_range": [20, 20]
			},
			"minecraft:collision_box": {
				"origin": [-8, 0, -8],
				"size": [16, 16, 16]
			},
			"minecraft:selection_box": {
				"origin": [-8, 0, -8],
				"size": [16, 16, 16]
			}
		},
		"permutations": [
			{
				"condition": "q.block_state('@namespace:can_deal_damage') == 'no'",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "tsunami_dungeons:golem_heart"
						}
					}
				}
			},
			{
				"condition": "q.block_state('@namespace:can_deal_damage') == 'ready'",
				"components": {
					"minecraft:light_emission": 5,
					"minecraft:material_instances": {
						"*": {
							"texture": "tsunami_dungeons:golem_heart_active"
						}
					}
				}
			},
			{
				"condition": "q.block_state('@namespace:can_deal_damage') == 'dealing_damage'",
				"components": {
					"minecraft:light_emission": 15,
					"minecraft:material_instances": {
						"*": {
							"texture": "tsunami_dungeons:golem_heart_damaging"
						}
					}
				}
			}
		]
	}
}
