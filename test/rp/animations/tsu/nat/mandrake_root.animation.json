{
	"format_version": "1.8.0",
	"animations": {
		"animation.tsu_nat.mandrake_root.walk": {
			"loop": true,
			"anim_time_update": "q.modified_distance_moved * 0.1",
			"bones": {
				"root": {
					"rotation": [0, 0, "math.cos(q.anim_time * 360*2) * 2"],
					"position": [0, "math.abs(math.cos(q.anim_time * 360)) * 3", 0]
				},
				"leftLeg": {
					"rotation": ["math.sin(q.anim_time * 360) * -45", 0, 0]
				},
				"rightLeg": {
					"rotation": ["math.sin(q.anim_time * 360) * 45", 0, 0]
				},
				"leftArm": {
					"rotation": [-180, 0, "12.5+ math.sin(q.anim_time * 360) * 20"]
				},
				"rightArm": {
					"rotation": [-180, 0, "-12.5 + math.sin(q.anim_time * 360) * -20"]
				}
			}
		}
	}
}