{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "tsu_nat:ground_fog_1",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/tsu/nat/particles/fx_Fog3"
      }
    },
    "components": {
      "minecraft:emitter_initialization": {
        "creation_expression": "v.direction_x = math.random(-1,1);v.direction_z = math.random(-1,1);"
      },
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.5
      },
      "minecraft:emitter_shape_box": {
        "offset": [0.5, 1.5, 0.5],
        "half_dimensions": [0.5, 0.5, 0.5],
        "direction": ["v.particle_random_1 * 2 - 1", 0, "v.particle_random_2 * 2 - 1"]
      },
      "minecraft:particle_initialization": {
        "per_render_expression": "v.size = v.particle_random_1 * 2 + 5;"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(5,10)"
      },
      "minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)"
      },
      "minecraft:particle_initial_speed": 0.2,
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_appearance_billboard": {
        "size": ["v.size", "v.size"],
        "facing_camera_mode": "emitter_transform_xz"
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#00FFFFFF",
            "0.46": "#45FFFFFF",
            "1.0": "#00FFFFFF"
          }
        }
      }
    }
  }
}
