{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "tsu_nat:spore",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/tsu/nat/particles/pixel_glow"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 0.5,
        "max_particles": 100
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 6
      },
      "minecraft:emitter_shape_box": {
        "offset": [0.5, 0.1, 0.5],
        "half_dimensions": [0.2, 0, 0.2],
        "surface_only": true,
        "direction": [0, 1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(10, 16)"
      },
      "minecraft:particle_initial_speed": "Math.random(0.2, 0.6)",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "math.cos((v.particle_age / 15) * (1000 + v.particle_random_3 * 3000)) * 10 * (v.particle_age / 15)",
          0,
          "math.sin((v.particle_age / 15) * (1000 + v.particle_random_3 * 3000)) * 10 * (v.particle_age / 15)"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [0.15, 0.15],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 8,
          "texture_height": 1,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [1, 1],
            "step_UV": [1, 0],
            "frames_per_second": 8,
            "max_frame": 8,
            "stretch_to_lifetime": true,
            "loop": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_random_4 / 1",
          "gradient": {
            "0.0": "#FF41E8FF",
            "1.0": "#FF196DC4"
          }
        }
      }
    }
  }
}
