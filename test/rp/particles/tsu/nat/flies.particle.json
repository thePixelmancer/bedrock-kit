{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "tsu_nat:flies",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/tsu/nat/particles/flies"
      }
    },
    "curves": {
      "variable.size": {
        "type": "linear",
        "input": "v.particle_random_1",
        "horizontal_range": 1,
        "nodes": [0.13, 0.52]
      }
    },
    "components": {
      "minecraft:emitter_initialization": {
        "creation_expression": "v.speed = 100;v.amplitude = 3;"
      },
      "minecraft:emitter_local_space": {
        "position": true,
        "rotation": false
      },
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 2,
        "max_particles": 100
      },
      "minecraft:emitter_lifetime_looping": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {
        "direction": ["v.particle_random_3", 0, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 10
      },
      "minecraft:particle_initial_spin": {
        "rotation": -90
      },
      "minecraft:particle_initial_speed": 2,
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "math.sin(v.particle_age*v.speed + v.particle_random_1*360) * v.particle_random_2 * v.amplitude",
          "3+math.sin(v.particle_age*v.speed + v.particle_random_2*360) * v.particle_random_3 * v.amplitude",
          "math.sin(v.particle_age*v.speed + v.particle_random_3*360) * v.particle_random_4 * v.amplitude"
        ],
        "direction": [
          "v.speed * math.cos(v.particle_age * v.speed + v.particle_random_1 * 360) * v.particle_random_2 * v.amplitude",
          "v.speed * math.cos(v.particle_age * v.speed + v.particle_random_2 * 360) * v.particle_random_3 * v.amplitude",
          "v.speed * math.cos(v.particle_age * v.speed + v.particle_random_3 * 360) * v.particle_random_4 * v.amplitude"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["0.4 * variable.size", "0.4 * variable.size"],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 1,
          "texture_height": 2,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [1, 1],
            "step_UV": [0, 1],
            "frames_per_second": 15,
            "max_frame": 2,
            "loop": true
          }
        }
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_random_2",
          "gradient": {
            "0.38": "#FFFFFFFF",
            "0.68": "#FFF5FFD1",
            "1.0": "#FFFFD4AD"
          }
        }
      }
    }
  }
}
