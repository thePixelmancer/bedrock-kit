{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "tsu_nat:vapor",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/tsu/nat/particles/cloud_2"
      }
    },
    "curves": {
      "variable.opacity": {
        "type": "catmull_rom",
        "input": "v.particle_age",
        "horizontal_range": "v.particle_lifetime",
        "nodes": [0, 0, 1, 0, 0]
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {
        "offset": [0.5, 5, 0.5],
        "direction": ["v.particle_random_1 * 2 - 1", 5, "v.particle_random_2 * 2 - 1"]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(4,8)"
      },
      "minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)"
      },
      "minecraft:particle_initial_speed": 4,
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 0.5
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["v.particle_random_1 * 2 + 2", "v.particle_random_1 * 2 + 2"],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "math.clamp(q.distance_from_camera/100,0,1) * variable.opacity",
          "gradient": {
            "0.0": "#00CECECE",
            "1.0": "#C78A8A8A"
          }
        }
      }
    }
  }
}
