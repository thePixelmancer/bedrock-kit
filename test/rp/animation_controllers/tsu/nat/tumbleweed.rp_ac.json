{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.tsu_nat.tumbleweed.move": {
      "states": {
        "default": {
          "transitions": [{ "walk": "query.modified_move_speed >= 0.2" }]
        },
        "walk": {
          "animations": ["move"],
          "transitions": [{ "default": "query.modified_move_speed < 0.2" }]
        }
      }
    }
  }
}
